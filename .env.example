# ============================================================
# Elsesser & Co. — пример переменных окружения.
# Скопируйте в .env / .env.local и заполните реальными значениями.
# Все ключи опциональны, но без них соответствующие фичи будут отключены.
# ============================================================

# ---------- Базовые ----------
APP_URL=http://elsesserandco-site.local
APP_ENV=development

# ---------- База данных ----------
REALESTATE_DB_HOST=localhost
REALESTATE_DB_NAME=realestate_db
REALESTATE_DB_USER=root
REALESTATE_DB_PASS=
REALESTATE_DB_CHARSET=utf8mb4

# ---------- SMTP (для email-уведомлений и подтверждения email) ----------
MAIL_TRANSPORT=smtp          # smtp | mail | log
MAIL_HOST=smtp.yandex.ru
MAIL_PORT=465
MAIL_USERNAME=noreply@elsesserandco.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl          # ssl | tls | ''
MAIL_FROM_ADDRESS=noreply@elsesserandco.com
MAIL_FROM_NAME="Elsesser & Co."

# ---------- OAuth: VK ID (https://id.vk.com/business/go) ----------
# Создайте приложение, в настройках укажите Redirect URI:
#   ${APP_URL}/oauth/vk/callback.php
# После создания скопируйте сюда VK ID (Client ID) и защищённый ключ.
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI=${APP_URL}/oauth/vk/callback.php

# ---------- OAuth: Яндекс (https://oauth.yandex.ru/client/new) ----------
# Создайте приложение, в настройках укажите Callback URL:
#   ${APP_URL}/oauth/yandex/callback.php
# Скопируйте ID и пароль приложения.
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=${APP_URL}/oauth/yandex/callback.php

# ---------- OAuth: Google (https://console.cloud.google.com/apis/credentials) ----------
# Создайте OAuth Client ID типа «Web application», Authorized redirect URI:
#   ${APP_URL}/oauth/google/callback.php
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/oauth/google/callback.php

# ---------- Telegram Login Widget (УДАЛЁН, legacy, не используется) ----------
# Раньше вход через Telegram был подключён, но в v2.2 убран:
# - из БД выпилены users.telegram_id, users.telegram_username (миграция 023_cleanup.sql)
# - колбэк oauth/telegram/callback.php не существует
# - виджет удалён из login.php и register.php
# Поля оставлены здесь, чтобы старые .env-файлы не падали с ошибкой парсинга.
# Для боевой интеграции потребуется новая миграция + восстановление колбэка.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ---------- Web Push (VAPID) ----------
# Генерация: см. README → "Web Push". Можно через npm web-push: `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@elsesserandco.com

# ---------- Яндекс.Карты (https://developer.tech.yandex.ru/) ----------
YANDEX_MAPS_API_KEY=
